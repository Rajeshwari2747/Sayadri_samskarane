<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4FBF5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_header_gradient"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📚 Eco Education"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Section 1 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌿 Trekking Do's and Don'ts"
            android:textColor="#2E7D32"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✅ Stay on marked trails\n✅ Carry your waste back\n✅ Respect wildlife habitats\n❌ Do not light fires\n❌ Do not pluck flowers or plants\n❌ Do not disturb nesting birds"
            android:textColor="#33691E"
            android:textSize="13sp"
            android:background="@drawable/bg_surface_card"
            android:padding="12dp"
            android:lineSpacingMultiplier="1.6"
            android:layout_marginBottom="16dp" />

        <!-- Section 2 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🐯 Wildlife Encounter Guidelines"
            android:textColor="#2E7D32"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✅ Maintain safe distance\n✅ Stay calm and move slowly\n✅ Report sightings via this app\n❌ Do not feed wild animals\n❌ Do not use flash photography\n❌ Do not corner or chase animals"
            android:textColor="#33691E"
            android:textSize="13sp"
            android:background="@drawable/bg_surface_card"
            android:padding="12dp"
            android:lineSpacingMultiplier="1.6"
            android:layout_marginBottom="16dp" />

        <!-- Section 3 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔥 Fire Safety Tips"
            android:textColor="#2E7D32"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✅ Report smoke immediately\n✅ Evacuate downwind direction\n✅ Call forest helpline: 1800-425-1666\n❌ Do not attempt to fight forest fires alone\n❌ Do not re-enter burned areas\n❌ Do not block emergency vehicles"
            android:textColor="#33691E"
            android:textSize="13sp"
            android:background="@drawable/bg_surface_card"
            android:padding="12dp"
            android:lineSpacingMultiplier="1.6"
            android:layout_marginBottom="16dp" />

    </LinearLayout>

</ScrollView>